# Huginn & Muninn -- Environment Configuration
# Copy to .env and adjust values for your deployment.

# LLM provider: "ollama" (default) or "openai" (for LiteLLM, OpenRouter, etc.)
HUGINN_LLM_PROVIDER=ollama

# LLM base URL -- Ollama or OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default LLM model
HUGINN_DEFAULT_MODEL=qwen3.5:9b

# API key for OpenAI-compatible providers (not needed for local Ollama)
# HUGINN_LLM_API_KEY=

# CORS origins (comma-separated, or * for all)
HUGINN_CORS_ORIGINS=*
